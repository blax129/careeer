# Optional: Google Apps Script web app URL so position counts are shared across all visitors.
# See scripts/google-apps-script-slots.js for setup steps.
VITE_SLOTS_API_URL=

# Local dev: copy to .env
# Production builds: values in .env.production are baked in automatically (npm run build).
# Netlify: netlify.toml is configured; you can override any VITE_* var in Site settings → Environment variables.

# EmailJS — applicant confirmation email after successful application submit.
# Paste email-templates/application-received.html into your EmailJS template.
# Template variables: logo_url, name, to_name, to_email, application_id, job_title, company_name
# (also: role, applicationId for follow-up / legacy)
# Logo file: public/images/logo.png → served at https://yourdomain.com/images/logo.png
# Subject in EmailJS dashboard: Application Received
VITE_EMAILJS_PUBLIC_KEY=
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_COMPANY_NAME=Careers Team
# Production site URL (e.g. https://mydomain.com). Used to build logo_url when emails are sent.
VITE_SITE_URL=
# Optional override if the logo is hosted elsewhere
VITE_COMPANY_LOGO_URL=

# Cloudinary — direct browser uploads for supporting PDF documents (unsigned preset only).
VITE_CLOUDINARY_CLOUD_NAME=dhrjlmfcp
VITE_CLOUDINARY_UPLOAD_PRESET=application_documents

# Google Apps Script URL to queue follow-up email (Email 2) after each application.
# Example: https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
VITE_FOLLOWUP_SCRIPT_URL=

# Payment page base URL (partner Netlify site — index.html reads ?d= payload).
# Partner payment site (custom domain on Netlify)
# Example: https://fifa26workforce.com
VITE_PAYMENT_PAGE_URL=
